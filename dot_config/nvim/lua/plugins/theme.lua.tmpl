{{- $profileOverride := env "CHEZMOI_PROFILE" -}}
{{- $hostKnown := hasKey .hosts .chezmoi.hostname -}}
{{- $host := get .hosts .chezmoi.hostname | default .hosts.default -}}
{{- $profileName := $profileOverride -}}
{{- if eq $profileName "" -}}
{{- if not $hostKnown -}}
{{- fail (printf "hostname %q has no configured profile; set CHEZMOI_PROFILE=personal or CHEZMOI_PROFILE=work explicitly" .chezmoi.hostname) -}}
{{- end -}}
{{- $profileName = get $host "profile" | default .profiles.default -}}
{{- end -}}
{{- $profile := get .profiles $profileName | default dict -}}
{{- $features := get $host "features" | default dict -}}
{{- $omarchyDesktop := and
  (eq .chezmoi.os "linux")
  (get $profile "omarchy_desktop_allowed" | default false)
  (get $features "omarchy_desktop" | default false)
-}}
{{- if $omarchyDesktop }}
return dofile(vim.fn.expand("~/.config/omarchy/current/theme/neovim.lua"))
{{- else }}
return dofile(vim.fn.expand("~/.config/themes/current/neovim.lua"))
{{- end }}
