" .vimrc - Evelyn King

set nocompatible
filetype plugin indent on
syntax enable
set backspace=indent,eol,start
set encoding=utf-8
set number
set relativenumber
set nohlsearch
set incsearch
set ruler
set tabstop=2
set softtabstop=2
set shiftwidth=2
set expandtab
inoremap jk <Esc>
set undodir=~/.vim/undo-dir
set undofile
set termguicolors
set background=dark
source ~/.config/themes/current/vim.vim
