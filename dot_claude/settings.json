{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-git-rewrites.py"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "effortLevel": "high"
}
