shell_prefer_zsh="${XDG_CONFIG_HOME:-${HOME}/.config}/shell/05_prefer_zsh.sh"
if [ -f "${shell_prefer_zsh}" ]; then
  # shellcheck source=/dev/null
  . "${shell_prefer_zsh}"
  shell_exec_preferred_zsh
fi
unset shell_prefer_zsh

shell_loader="${XDG_CONFIG_HOME:-${HOME}/.config}/shell/interactive.sh"

if [ -f "${shell_loader}" ]; then
  # shellcheck source=/dev/null
  . "${shell_loader}"
else
  printf 'Missing source file: %s\n' "${shell_loader}" >&2
fi
