#!/usr/bin/env bash

set -euo pipefail

command -v uv >/dev/null 2>&1 || {
  printf 'sync-uv: missing required command: uv\n' >&2
  exit 1
}

xargs -P4 -I{} uv tool install {} <<'EOF'
black
conda-lock
docling
mypy
poethepoet
ruff
unidep[all]
EOF

uv tool install pre-commit --with pre-commit-uv
uv tool upgrade --all
