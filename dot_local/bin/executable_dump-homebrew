#!/usr/bin/env bash

set -euo pipefail

SCRIPT_NAME="dump-homebrew"
BREWFILE=""
SOURCE_DIR=""
export HOMEBREW_NO_AUTO_UPDATE="${HOMEBREW_NO_AUTO_UPDATE:-1}"

usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [--file <path> | --source-dir <path>]

Write the current top-level Homebrew state to a Brewfile.

Options:
  --file <path>        Output Brewfile path. Defaults to ~/.Brewfile.
  --source-dir <path>  Resolve the chezmoi source path for ~/.Brewfile in the
                       given repo and write there instead.
  -h, --help           Show this help text.
EOF
}

die() {
  printf '[%s] %s\n' "${SCRIPT_NAME}" "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

require_macos() {
  [ "$(uname -s)" = "Darwin" ] || die "This command only supports macOS"
}

resolve_brewfile() {
  if [ -n "${BREWFILE}" ] && [ -n "${SOURCE_DIR}" ]; then
    die "Use either --file or --source-dir, not both"
  fi

  if [ -n "${SOURCE_DIR}" ]; then
    repo_brewfile="${SOURCE_DIR%/}/dot_Brewfile"
    if [ -f "${repo_brewfile}" ] || [ ! -e "${repo_brewfile}" ]; then
      printf '%s\n' "${repo_brewfile}"
      return 0
    fi

    require_command chezmoi
    chezmoi source-path --refresh-externals=never --source "${SOURCE_DIR}" ~/.Brewfile
    return 0
  fi

  if [ -n "${BREWFILE}" ]; then
    printf '%s\n' "${BREWFILE}"
    return 0
  fi

  printf '%s\n' "${HOME}/.Brewfile"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --file)
      [ "$#" -ge 2 ] || die "Missing value for --file"
      BREWFILE="$2"
      shift 2
      ;;
    --source-dir)
      [ "$#" -ge 2 ] || die "Missing value for --source-dir"
      SOURCE_DIR="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

require_macos
require_command brew

output_file="$(resolve_brewfile)"

brew bundle dump \
  --file "${output_file}" \
  --force \
  --describe \
  --no-restart \
  --no-vscode \
  --no-go \
  --no-cargo \
  --no-uv
