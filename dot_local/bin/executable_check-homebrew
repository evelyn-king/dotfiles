#!/usr/bin/env bash

set -euo pipefail

SCRIPT_NAME="check-homebrew"
BREWFILE="${HOME}/.Brewfile"
NO_UPGRADE=1
export HOMEBREW_NO_AUTO_UPDATE="${HOMEBREW_NO_AUTO_UPDATE:-1}"

usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [--file <path>] [--upgrade]

Check whether the local Homebrew installation matches the managed Brewfile.

Options:
  --file <path>  Brewfile to check. Defaults to ~/.Brewfile.
  --upgrade      Treat outdated packages as drift.
  -h, --help     Show this help text.
EOF
}

die() {
  printf '[%s] %s\n' "${SCRIPT_NAME}" "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

require_macos() {
  [ "$(uname -s)" = "Darwin" ] || die "This command only supports macOS"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --file)
      [ "$#" -ge 2 ] || die "Missing value for --file"
      BREWFILE="$2"
      shift 2
      ;;
    --upgrade)
      NO_UPGRADE=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

require_macos
require_command brew
[ -f "${BREWFILE}" ] || die "Brewfile not found: ${BREWFILE}"

args=(bundle check --file "${BREWFILE}" --verbose)
if [ "${NO_UPGRADE}" -eq 1 ]; then
  args+=(--no-upgrade)
fi

brew "${args[@]}"
