#!/bin/sh

# Script version: 2026-03-20-doom-emacs-guard

if ! command -v emacs >/dev/null 2>&1; then
  echo "Emacs is not installed; skipping Doom Emacs install."
  exit 0
fi

if [ -x "$HOME/.config/emacs/bin/doom" ]; then
  echo "Installing Doom Emacs packages..."
  "$HOME/.config/emacs/bin/doom" install --aot --no-config --env
else
  echo "Doom Emacs not found at ~/.config/emacs; skipping Doom Emacs install."
fi
